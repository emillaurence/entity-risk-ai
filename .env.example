# ─────────────────────────────────────────────────────────────────────────────
# App credentials
# ─────────────────────────────────────────────────────────────────────────────
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=

# ─────────────────────────────────────────────────────────────────────────────
# LLM config
# ─────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
# Override the planner model (defaults to ANTHROPIC_MODEL_SONNET).
# Example: PLANNER_MODEL=claude-haiku-4-5-20251001
PLANNER_MODEL=

# ─────────────────────────────────────────────────────────────────────────────
# App config
# ─────────────────────────────────────────────────────────────────────────────
# Remote MCP server URL — enables the "Remote (Railway MCP)" backend option in the UI.
REMOTE_MCP_URL=https://entity-risk-ai-production.up.railway.app/mcp

# Dev auth bypass — set to true to skip the login gate during local development.
DEV_BYPASS_AUTH=false

# ─────────────────────────────────────────────────────────────────────────────
# Kong integration (all optional — none are required unless you enable Kong mode)
# ─────────────────────────────────────────────────────────────────────────────

# AI Gateway — route Anthropic calls through Kong
#   KONG_PROXY_URL     — Serverless proxy URL shown in Konnect Gateway Manager
#                        (e.g. https://abc.au.kong.tech). This is where the app
#                        sends traffic. NOT the Konnect API URL.
#   KONG_AI_GATEWAY_*  — route paths and API key for the AI Gateway
KONG_PROXY_URL=
KONG_AI_GATEWAY_ENABLED=false
KONG_AI_GATEWAY_ROUTE_PATH=/ai
KONG_AI_GATEWAY_SONNET_ROUTE_PATH=/ai/sonnet
KONG_AI_GATEWAY_API_KEY=

# MCP Gateway — route MCP tool calls through Kong
#   KONG_MCP_GATEWAY_*  — route path, API key, and upstream URL
KONG_MCP_GATEWAY_ENABLED=false
KONG_MCP_GATEWAY_ROUTE_PATH=/mcp
KONG_MCP_GATEWAY_API_KEY=
KONG_MCP_UPSTREAM_URL=https://entity-risk-ai-production.up.railway.app/mcp

# ACL enforcement — per-role tool access via Kong consumer groups
#   Requires KONG_MCP_GATEWAY_ENABLED=true and UI backend = "Kong MCP Gateway".
#   When false, policy.py enforces the same restrictions in-app (app-side fallback).
KONG_MCP_ACL_POLICY_ENABLED=false
# jr-analyst-app consumer → jr-analyst group (restricted tools)
KONG_MCP_ACL_JR_API_KEY=
# sr-analyst-app consumer → sr-analyst group (full access)
KONG_MCP_ACL_SR_API_KEY=

# Konnect management — used by decK to manage the control plane (not for traffic)
#   Sign in at https://cloud.konghq.com → My Account → Personal Access Tokens
#   KONG_KONNECT_ADDR encodes the region (e.g. https://au.api.konghq.com for AU).
KONG_KONNECT_ADDR=https://au.api.konghq.com
KONG_KONNECT_CONTROL_PLANE_NAME=entity-risk-ai
KONG_KONNECT_TOKEN=
KONG_KONNECT_CONTROL_PLANE_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Notebook test gate
# ─────────────────────────────────────────────────────────────────────────────
# Set to true only when running Kong notebooks against a real Konnect org.
ENABLE_LIVE_KONG_NOTEBOOK_TESTS=false
