# Anthropic API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
# PLANNER_MODEL — model used by InvestigationPlanner only (defaults to ANTHROPIC_MODEL_SONNET).
# Override to revert the planner to Haiku: PLANNER_MODEL=claude-haiku-4-5-20251001
PLANNER_MODEL=

# Neo4j DB
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=

# Remote MCP server (optional — enables the "Remote (Railway MCP)" option in the UI)
REMOTE_MCP_URL=https://entity-risk-ai-production.up.railway.app/mcp

# Dev auth bypass (optional — set to true to skip the login gate during local development)
DEV_BYPASS_AUTH=false

# ─────────────────────────────────────────────────────────────────────────────
# Kong integration (all optional — none are required unless you enable Kong mode)
# ─────────────────────────────────────────────────────────────────────────────

# Phase 505 — Konnect control plane targeting (read by KongSettings in src/config.py)
#    Sign in at https://cloud.konghq.com → My Account → Personal Access Tokens
#    KONG_KONNECT_ADDR encodes the region (e.g. https://au.api.konghq.com for AU).
KONG_KONNECT_ADDR=https://au.api.konghq.com
KONG_KONNECT_CONTROL_PLANE_NAME=entity-risk-ai
KONG_KONNECT_TOKEN=
KONG_KONNECT_CONTROL_PLANE_ID=

# Phase 506+ — gateway vars (NOT read by KongSettings; used by KongAIGatewaySettings / KongMCPGatewaySettings)
#    KONG_PROXY_URL        — Serverless proxy URL shown in Konnect Gateway Manager
#    KONG_AI_GATEWAY_*     — route path and API key for the AI Gateway (phase 506)
#    KONG_MCP_GATEWAY_*    — route path, API key, and upstream URL for the MCP Gateway (phase 507)
KONG_PROXY_URL=
KONG_AI_GATEWAY_ENABLED=false
KONG_AI_GATEWAY_ROUTE_PATH=/ai
KONG_AI_GATEWAY_SONNET_ROUTE_PATH=/ai/sonnet
KONG_AI_GATEWAY_API_KEY=
KONG_MCP_GATEWAY_ENABLED=false
KONG_MCP_GATEWAY_ROUTE_PATH=/mcp
KONG_MCP_GATEWAY_API_KEY=
KONG_MCP_UPSTREAM_URL=https://entity-risk-ai-production.up.railway.app/mcp
# Phase 509 — Kong MCP ACL policy (requires KONG_MCP_GATEWAY_ENABLED=true)
# When true and UI backend is "Kong MCP Gateway", Kong enforces tool access per consumer group.
# App-side tool allowlist (policy.py) is bypassed — Kong is the authority.
# Keep false to use app-based role policy without gateway enforcement.
KONG_MCP_ACL_POLICY_ENABLED=false
# Per-role API keys for Kong ACL enforcement (required when KONG_MCP_ACL_POLICY_ENABLED=true).
# Each key maps to a dedicated Kong consumer assigned to the corresponding consumer group.
# See kong/consumer_groups.yaml for the consumer/group setup.
# jr-analyst-app consumer → jr-analyst group (restricted tools)
KONG_MCP_ACL_JR_API_KEY=
# sr-analyst-app consumer → sr-analyst group (all tools)
KONG_MCP_ACL_SR_API_KEY=

# Notebook live-test gate — set to true only when running notebook 505+ with a real Konnect org
ENABLE_LIVE_KONG_NOTEBOOK_TESTS=false
